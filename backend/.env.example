# Flask / server
FLASK_ENV=development
PORT=5000

# CORS / frontend origins
# Primary React frontend (Vercel) origin, e.g. https://ngo-calendar.vercel.app
FRONTEND_ORIGIN=https://your-frontend-domain.vercel.app
# Optional explicit Vercel origin override
VERCEL_FRONTEND_ORIGIN=https://your-frontend-domain.vercel.app

# Firebase / Google service account
# Full JSON for the shared service account used by BOTH Firebase Admin
# and Google Calendar API (Render recommended pattern: store JSON in env var).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"REPLACE","private_key":"REPLACE_WITH_ESCAPED_NEWLINES","client_email":"service-account@your-project-id.iam.gserviceaccount.com","client_id":"REPLACE","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/service-account%40your-project-id.iam.gserviceaccount.com"}

# Optional explicit Firebase settings (some values may be inferred from the JSON above)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com

# Google Calendar
GOOGLE_CALENDAR_ID=your-shared-calendar-id@group.calendar.google.com
DEFAULT_TIMEZONE=UTC

# Resend email
RESEND_API_KEY=re_********************************
RESEND_FROM_EMAIL="NGO Calendar <no-reply@your-domain.org>"

