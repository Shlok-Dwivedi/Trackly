# Trackly Environment Variables
# Copy this file to .env and fill in your values

# Google Calendar OAuth - Get from https://console.cloud.google.com/
# 1. Enable Google Calendar API
# 2. Create OAuth 2.0 credentials
# 3. Add scope: https://www.googleapis.com/auth/calendar.events
# 4. Add authorized redirect URI: http://localhost:8080/auth/google/callback
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Firebase Config (already in your project)
# VITE_FIREBASE_API_KEY=your_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# VITE_FIREBASE_APP_ID=your_app_id

# Supabase Config (if using)
# VITE_SUPABASE_URL=your_supabase_url
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

